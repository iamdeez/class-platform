MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=class_platform
MYSQL_USER=class_platform
MYSQL_PASSWORD=class_platform

MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=root
MONGO_DATABASE=class_platform

# anthropic-java SDK(AnthropicOkHttpClient.fromEnv())가 OS 환경변수에서 직접 읽는다.
# application.yml을 거치지 않으므로, 로컬에서 AI 태깅을 실제로 호출하려면 셸에 직접 export 필요.
ANTHROPIC_API_KEY=
# AI_ENRICHMENT_MODEL=claude-haiku-4-5

# REDIS_HOST=localhost
# REDIS_PORT=6379
# POPULARITY_CACHE_SYNC_INTERVAL_MS=10000
# POST_DETAIL_CACHE_TTL_SECONDS=300

# --- 배포 환경 전용 (005-ci-cd-deploy) ---
# 로컬 개발에서는 미설정 상태로 두면 위 로컬 기본값이 그대로 사용된다.
# 아래 값들은 Render의 Environment Variables 화면에 직접 입력하며, 이 파일에는 절대 실제 값을 채우지 않는다.

# 배포 시 컨테이너가 수신할 포트(Render가 주입)
# PORT=8080

# Aiven MySQL 등 외부 관리형 MySQL의 전체 JDBC URL(호스트·포트·sslMode 포함)
# MYSQL_JDBC_URL=jdbc:mysql://{host}:{port}/{database}?sslMode=REQUIRED&serverTimezone=Asia/Seoul

# MongoDB Atlas 등 외부 관리형 MongoDB의 전체 연결 문자열(mongodb+srv:// 포함)
# MONGODB_URI=mongodb+srv://{user}:{password}@{cluster-host}/{database}?retryWrites=true&w=majority

# Upstash Redis 등 외부 관리형 Redis 접속 정보(비밀번호·TLS 필수)
# REDIS_HOST={host}
# REDIS_PORT={port}
# REDIS_PASSWORD={password}
# REDIS_SSL_ENABLED=true

# Render가 GitHub Actions로부터 배포 트리거를 받는 URL(GitHub Actions Secret으로 등록, 이 파일에는 값 금지)
# RENDER_DEPLOY_HOOK_URL=
